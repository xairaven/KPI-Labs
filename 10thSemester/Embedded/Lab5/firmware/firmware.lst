          .list
         
          .def Counter = R16
          .def Temp = R17
         
          .CSEG
          .ORG 0x0000
C:000000 c000      RJMP Reset
         
          Reset:
             ; Initialize stack pointer
C:000001 e51f          LDI Temp, low(RAMEND)
C:000002 bf1d          OUT SPL, Temp
C:000003 e014          LDI Temp, high(RAMEND)
C:000004 bf1e          OUT SPH, Temp
         
          Init:
             ; Configure Port D as output
C:000005 ef1f          LDI Temp, 0xFF
C:000006 bb11          OUT DDRD, Temp
C:000007 bb12          OUT PORTD, Temp
             
             ; Clear counter
C:000008 2700          CLR Counter
         
          Loop:
             ; Load base address of sine table into Z register
C:000009 e2e4          LDI ZL, low(Sinus*2)
C:00000a e0f0          LDI ZH, high(Sinus*2)
         
             ; Add current counter value to address
C:00000b 0fe0          ADD ZL, Counter
C:00000c 2711          CLR Temp
C:00000d 1ff1          ADC ZH, Temp
         
             ; Read sine value from flash memory
C:00000e 9114          LPM Temp, Z
         
             ; Output value to DAC (Port D)
C:00000f bb12          OUT PORTD, Temp
         
             ; Increment counter (auto-wraps to 0 after 255)
C:000010 9503          INC Counter
         
             ; Repeat loop
C:000011 cff7          RJMP Loop
         
         ; Sine wave values table (256 values)
          Sinus:
          .DB 64,65,67,68,70,72,73,75
